---
interface Props {
  title: string;
  paragraphs: string[];
}

const { title, paragraphs } = Astro.props;
---

<section class="content-section content-section--copy">
  <div class="section-heading">
    <p class="section-heading__eyebrow">Contexto</p>
    <h2>{title}</h2>
  </div>

  <div class="copy-grid">
    {paragraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>
</section>

