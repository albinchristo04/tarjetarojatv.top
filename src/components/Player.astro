---
import type { NormalizedMatch } from '../lib/types';
import TimezoneRow from './TimezoneRow.astro';

interface Props {
  match: NormalizedMatch;
}

const { match } = Astro.props;
const defaultChannel = match.channels[0];
const defaultServer = defaultChannel?.servers[0];
const defaultSrc = defaultServer?.url ?? '';
---

<section class="player-shell">
  <div class="player-shell__frame">
    {defaultSrc ? (
      <iframe
        id="match-player"
        src={defaultSrc}
        title={`Ver ${match.homeTeam} vs ${match.awayTeam} en vivo`}
        loading="lazy"
        allow="autoplay; encrypted-media; picture-in-picture; fullscreen"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
      ></iframe>
    ) : (
      <div class="player-shell__empty">
        <h2>Transmision pendiente</h2>
        <p>Este partido aun no tiene canales disponibles. Vuelve a revisar en la siguiente actualizacion.</p>
      </div>
    )}
  </div>

  <div class="player-shell__controls">
    <div class="pill-row">
      <span class="pill-row__label">Idiomas</span>
      {match.availableLanguages.map((language) => (
        <span class="pill">{language}</span>
      ))}
    </div>

    {match.channels.length > 0 && (
      <>
        <div class="pill-row" data-channel-group>
          <span class="pill-row__label">Canales</span>
          {match.channels.map((channel, index) => (
            <button
              type="button"
              class={`pill pill--button ${index === 0 ? 'is-active' : ''}`}
              data-channel-url={channel.servers[0]?.url}
              data-channel-id={channel.channelId}
              data-channel-index={index}
            >
              {channel.displayName}
            </button>
          ))}
        </div>

        <div class="pill-row" data-server-group>
          <span class="pill-row__label">Servidor</span>
          {defaultChannel.servers.map((server, index) => (
            <button
              type="button"
              class={`pill pill--button ${index === 0 ? 'is-active' : ''}`}
              data-server-id={server.id}
            >
              {server.label}
            </button>
          ))}
        </div>
      </>
    )}
  </div>

  <TimezoneRow items={match.timezones} />
</section>

<script is:inline define:vars={{ channels: JSON.stringify(match.channels) }}>
  const channelData = JSON.parse(channels);
  const iframe = document.getElementById('match-player');
  const channelButtons = Array.from(document.querySelectorAll('[data-channel-index]'));
  const serverButtons = Array.from(document.querySelectorAll('[data-server-id]'));

  let activeChannelIndex = 0;
  let activeServerId = channelData[0]?.servers[0]?.id ?? 1;

  const updatePlayer = () => {
    if (!iframe) return;
    const channel = channelData[activeChannelIndex];
    const server = channel?.servers.find((entry) => entry.id === activeServerId) ?? channel?.servers[0];
    if (server) {
      iframe.src = server.url;
    }
  };

  channelButtons.forEach((button, index) => {
    button.addEventListener('click', () => {
      activeChannelIndex = index;
      channelButtons.forEach((entry) => entry.classList.remove('is-active'));
      button.classList.add('is-active');
      updatePlayer();
    });
  });

  serverButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeServerId = Number(button.getAttribute('data-server-id') || '1');
      serverButtons.forEach((entry) => entry.classList.remove('is-active'));
      button.classList.add('is-active');
      updatePlayer();
    });
  });
</script>
